# Пример переменных окружения. Скопируйте в .env и подставьте значения.

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=interview_qa
QDRANT_SHARD_NUMBER=2
QDRANT_REPLICATION_FACTOR=1

# Модель эмбеддингов OpenAI
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=16

# Векторизация
VECTORIZATION_MAX_CHUNK_CHARS=1000
VECTORIZATION_OVERLAP=100
INTERVIEW_TOP_K=5

# DOCX-источник и состояние индекса
INTERVIEW_DOCX_PATH=D:\Yandex.Disk\Собесы\Топ вопросов на собеседовании Python.docx
INGEST_STATE_PATH=data/interview_ingest_state.json

# Период проверки, изменился ли docx (часы)
INGEST_INTERVAL_HOURS=1

# Только для Docker Compose:
# путь на хосте, который будет смонтирован в контейнер как /data/interview_questions.docx
DOCX_SOURCE_PATH_HOST=D:\Yandex.Disk\Собесы\Топ вопросов на собеседовании Python.docx
