# Скопируйте в .env и подставьте значения.

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=interview_qa

# Embeddings
EMBEDDING_BATCH_SIZE=16
EMBEDDING_DIM=768

# DOCX-источник
INTERVIEW_DOCX_PATH=./Топ вопросов на собеседовании Python.docx
# INTERVIEW_DOCX_PATH=D:\Yandex.Disk\Собесы\Топ вопросов на собеседовании Python.docx
INGEST_STATE_PATH=data/interview_ingest_state.json# Ollama LLM
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SEC=120

# Docker Compose: путь к docx на хосте
# DOCX_SOURCE_PATH_HOST=D:\Yandex.Disk\Собесы\Топ вопросов на собеседовании Python.docx
DOCX_SOURCE_PATH_HOST=./Топ вопросов на собеседовании Python.docx
